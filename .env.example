# Root helper file. Render uses server/.env.example; Vercel uses client env variables.

# Client / Vercel
VITE_API_BASE_URL=https://your-render-service.onrender.com

# Server / Render
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/now-here
JWT_SECRET=use-a-64-character-random-secret-generated-with-node-crypto
CLIENT_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173
AUTH_COOKIE_SAMESITE=lax
AUTH_TOKEN_RESPONSE=false
